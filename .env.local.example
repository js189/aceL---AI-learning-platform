# Featherless AI (OpenAI-compatible)
FEATHERLESS_API_KEY=your_featherless_api_key
NEXT_PUBLIC_FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# Optional: faster models for speed (default: gpt-oss-120b main, gpt-oss-20b fast)
# FEATHERLESS_CHAT_MODEL=openai/gpt-oss-20b
# FEATHERLESS_FAST_MODEL=openai/gpt-oss-20b

# Optional: Resend for Active Recall email notifications
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Adaptive Learning <notifications@yourdomain.com>

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Google OAuth — required for "Continue with Google"
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: http://localhost:3000/api/auth/callback/google
# 4. Copy Client ID and Client Secret here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
