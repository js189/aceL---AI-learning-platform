# Featherless AI (OpenAI-compatible)
FEATHERLESS_API_KEY=your_featherless_api_key
NEXT_PUBLIC_FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# Model overrides (default: openai/gpt-oss-20b for all)
# FEATHERLESS_CHAT_MODEL=openai/gpt-oss-20b
# FEATHERLESS_FAST_MODEL=openai/gpt-oss-20b
# FEATHERLESS_VISION_MODEL=openai/gpt-oss-20b

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
